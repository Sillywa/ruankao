<view class="page">
  <view class="hero">
    <view class="eyebrow">RUANKAO ALERT</view>
    <view class="title">成绩出来时，<text>第一时间告诉你</text></view>
    <view class="subtitle">每 30 分钟检查中国计算机技术职业资格网的当年最新成绩查询通知。</view>
  </view>

  <view class="card status-card">
    <view class="status-head">
      <view class="status-dot {{subscribed ? 'active' : ''}}"></view>
      <view class="status-title">{{subscribed ? '提醒已订阅' : '尚未订阅提醒'}}</view>
    </view>
    <view class="status-text" wx:if="{{subscribed}}">你已完成订阅，可以随时立即检查最新通知。</view>
    <view class="status-text" wx:else>点击下方按钮，授权接收一次成绩公布提醒。</view>

    <button class="subscribe-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handlePrimaryAction">
      {{subscribed ? '立即检查' : '订阅成绩提醒'}}
    </button>
    <button
      wx:if="{{subscribed}}"
      class="cancel-btn"
      loading="{{cancelling}}"
      disabled="{{cancelling}}"
      bindtap="cancelSubscription"
    >
      取消订阅
    </button>
    <view class="hint" wx:if="{{!subscribed}}">点击按钮授权订阅；取消订阅后可以重新授权。</view>
    <view class="hint" wx:else>系统仍会每 30 分钟自动检查；手动检查结果也会立即显示在下方。</view>
  </view>

  <view class="card info-card">
    <view class="section-title">检查状态</view>
    <view class="row">
      <text class="label">最近检查</text>
      <text class="value">{{lastCheckedAt || '等待云端首次检查'}}</text>
    </view>
    <view class="row">
      <text class="label">当前结果</text>
      <text class="value">{{latestNotice ? '已发现通知' : '暂无当年成绩通知'}}</text>
    </view>
    <view class="announcement-row" bindtap="openLatestNotice">
      <view class="announcement-head">
        <text class="announcement-label">最新公告</text>
        <text class="announcement-action" wx:if="{{latestAnnouncement}}">复制链接 ›</text>
      </view>
      <block wx:if="{{latestAnnouncement}}">
        <text class="announcement-title clickable">{{latestAnnouncement.title}}</text>
        <text class="announcement-date">发布日期：{{latestAnnouncement.dateText}}</text>
      </block>
      <text class="announcement-title empty" wx:else>暂无公告</text>
    </view>
  </view>

  <view class="footer">通知来源：中国计算机技术职业资格网</view>
</view>
