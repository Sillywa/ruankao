<view class="page">
  <view class="summary">
    <text>仅管理员可见，用于查看成绩通知发送总体结果。</text>
    <text class="help-link" bindtap="openFieldHelp">字段说明</text>
  </view>

  <view class="error-card" wx:if="{{errorMessage}}">{{errorMessage}}</view>

  <block wx:if="{{loading && !initialized && !errorMessage}}">
    <view class="card stats-card">
      <view class="skeleton-line skeleton-title"></view>
      <view class="skeleton-line skeleton-stat-wide"></view>
      <view class="skeleton-grid">
        <view class="skeleton-stat" wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this">
          <view class="skeleton-line skeleton-number"></view>
          <view class="skeleton-line skeleton-label"></view>
        </view>
      </view>
      <view class="skeleton-status">
        <view class="skeleton-line skeleton-status-item" wx:for="{{[1,2,3,4]}}" wx:key="*this"></view>
      </view>
    </view>
    <view class="section-head">
      <view class="skeleton-line skeleton-section-title"></view>
      <view class="skeleton-line skeleton-refresh"></view>
    </view>
    <view class="attempt skeleton-card" wx:for="{{[1,2]}}" wx:key="*this">
      <view class="skeleton-head">
        <view class="skeleton-line skeleton-badge"></view>
        <view class="skeleton-line skeleton-time"></view>
      </view>
      <view class="skeleton-line skeleton-notice"></view>
      <view class="skeleton-line skeleton-row"></view>
      <view class="skeleton-line skeleton-row short"></view>
    </view>
  </block>

  <view class="card stats-card" wx:if="{{stats}}">
    <view class="section-title">发送概览</view>
    <view class="stat subscriber-stat">
      <view class="number">{{stats.totalSubscribers}}</view>
      <view class="label">总订阅用户数</view>
    </view>
    <view class="grid">
      <view class="stat">
        <view class="number">{{stats.totalSent}}</view>
        <view class="label">成功用户数</view>
      </view>
      <view class="stat danger">
        <view class="number">{{stats.totalFailed}}</view>
        <view class="label">失败用户数</view>
        <button class="retry-btn" wx:if="{{stats.totalFailed > 0}}" loading="{{retrying}}" disabled="{{retrying}}" bindtap="retryFailedNotifications">重试</button>
      </view>
      <view class="stat danger">
        <view class="number">{{stats.totalAuthFailed}}</view>
        <view class="label">授权失效用户数</view>
      </view>
      <view class="stat warning">
        <view class="number">{{stats.totalUpdateFailed}}</view>
        <view class="label">记录更新失败</view>
      </view>
      <view class="stat">
        <view class="number">{{stats.totalTasks}}</view>
        <view class="label">公告发送任务</view>
      </view>
      <view class="stat">
        <view class="number">{{stats.totalAttempts}}</view>
        <view class="label">发送流水</view>
      </view>
    </view>
    <view class="task-status">
      <text>已完成 {{stats.finishedTasks}}</text>
      <text>发送中 {{stats.sendingTasks}}</text>
      <text>异常 {{stats.failedTasks}}</text>
      <text>超时 {{stats.timeoutTasks}}</text>
    </view>
  </view>

  <view class="section-head" wx:if="{{initialized && !errorMessage}}">
    <view class="section-title">发送流水</view>
    <view class="refresh" bindtap="loadStats">刷新</view>
  </view>

  <block wx:if="{{initialized && !errorMessage}}">
    <view class="attempt" wx:for="{{recentAttempts}}" wx:key="_id" wx:for-item="attempt">
      <view class="task-head">
        <view class="status {{attempt.status}}">{{attempt.status}}</view>
        <text class="time">{{attempt.createdAt}}</text>
      </view>
      <view class="notice">{{attempt.noticeTitle || '未记录公告标题'}}</view>
      <view class="meta">
        <text>本次成功 {{attempt.sent}}</text>
        <text>本次失败 {{attempt.failed}}</text>
      </view>
      <view class="meta">
        <text>授权失效 {{attempt.authFailed}}</text>
        <text>更新失败 {{attempt.updateFailed}}</text>
      </view>
      <view class="sub-meta">
        <text>{{attempt.triggerType || 'unknown'}}</text>
        <text>发送用户 {{attempt.total}}</text>
      </view>
      <view class="result-list" wx:if="{{attempt.results.length}}">
        <view class="result-row" wx:for="{{attempt.results}}" wx:key="subscriberId" wx:for-item="result">
          <view class="result-main">
            <text class="result-status {{result.status}}">{{result.status}}</text>
            <text class="openid">{{result.openid}}</text>
          </view>
          <view class="result-error" wx:if="{{result.errCode || result.errorText}}">
            <text wx:if="{{result.errCode}}">错误码 {{result.errCode}}</text>
            <text wx:if="{{result.errorText}}">{{result.errorText}}</text>
          </view>
        </view>
      </view>
      <view class="result-error task-error" wx:if="{{attempt.error}}">{{attempt.error}}</view>
    </view>
  </block>

  <view class="section-head" wx:if="{{initialized && !errorMessage}}">
    <view class="section-title">公告发送任务</view>
  </view>

  <block wx:if="{{initialized && !errorMessage}}">
    <view class="task" wx:for="{{recentTasks}}" wx:key="_id">
      <view class="task-head">
        <view class="status {{item.status}}">{{item.status}}</view>
        <text class="time">{{item.createdAt}}</text>
      </view>
      <view class="notice">{{item.noticeTitle || '未记录公告标题'}}</view>
      <view class="meta">
        <text>成功 {{item.sent}}</text>
        <text>失败 {{item.failed}}</text>
      </view>
      <view class="meta">
        <text>授权失效 {{item.authFailed}}</text>
        <text>更新失败 {{item.updateFailed}}</text>
      </view>
      <view class="sub-meta">
        <text>{{item.triggerType || 'unknown'}}</text>
        <text wx:if="{{item.finishedAt}}">完成 {{item.finishedAt}}</text>
      </view>
    </view>
  </block>

  <view class="empty" wx:if="{{initialized && !errorMessage && !recentTasks.length && !recentAttempts.length}}">暂无发送记录</view>
  <view class="loading" wx:if="{{loading && initialized}}">正在加载...</view>
</view>
