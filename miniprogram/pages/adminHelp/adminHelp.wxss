.page { min-height: 100vh; padding: 28rpx 30rpx 50rpx; background: #f3f6fb; box-sizing: border-box; }
.summary { padding: 8rpx 6rpx 28rpx; color: #8b95a7; font-size: 23rpx; line-height: 1.55; }
.card { margin-bottom: 22rpx; padding: 30rpx; border-radius: 22rpx; background: #fff; box-shadow: 0 10rpx 34rpx rgba(29, 50, 94, .06); }
.field-card { color: #6f7a8f; font-size: 23rpx; line-height: 1.55; }
.section-title { margin-bottom: 18rpx; color: #25314a; font-size: 30rpx; font-weight: 700; }
.field-row { display: flex; gap: 18rpx; padding: 14rpx 0; border-top: 1rpx solid #eef2f8; }
.field-name { flex: 0 0 132rpx; color: #25314a; font-weight: 700; }
